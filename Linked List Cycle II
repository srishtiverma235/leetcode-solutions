/**
 * Definition for singly-linked list.
 * class ListNode {
 *     int val;
 *     ListNode next;
 *     ListNode(int x) {
 *         val = x;
 *         next = null;
 *     }
 * }
 */
public class Solution {
    public ListNode detectCycle(ListNode head) {
        ListNode fast=head,slow=head;
        if(head==null||head.next==null){
            return null;
        }
        while(true){
            slow=slow.next;
            fast=fast.next.next;
            if(slow==null||fast==null||fast.next==null){
                return null;
            }
            if(slow==fast){
                ListNode third=head;
                while(third!=fast){
                    fast=fast.next;
                    third=third.next;
                }
                return third;
            }
        

        }
        
    }
}
